{
  "testCases": [
    {
      "name": "Glucose",
      "input": "My glucose was 120 mg/dL this morning",
      "expected": {
        "type": "glucose",
        "fields": { "value": 120, "unit": "mg/dL" },
        "needsClarification": false
      }
    },
    {
      "name": "Meds (string dosage — heuristic format)",
      "input": "I took 500mg of Tylenol",
      "expected": {
        "type": "medication",
        "fields": { "medication": "Tylenol", "dosage": "500mg" },
        "needsClarification": false
      }
    },
    {
      "name": "Meal (determiner stripped)",
      "input": "I ate a salad for lunch",
      "expected": {
        "type": "meal",
        "fields": { "meal": "salad", "carbs": null },
        "needsClarification": false
      }
    },
    {
      "name": "Symptom-Clarify (unknown token)",
      "input": "I feel weird",
      "expected": {
        "type": "symptom",
        "fields": { "symptom": null, "severity": null },
        "needsClarification": true
      }
    },
    {
      "name": "Symptom-Headache (recognized, severity optional)",
      "input": "I have a headache",
      "expected": {
        "type": "symptom",
        "fields": { "symptom": "headache", "severity": null },
        "needsClarification": false
      }
    },
    {
      "name": "Medication-by-name (Tylenol with ibuprofen → two med events)",
      "input": "Tylenol with ibuprofen",
      "expectedEvents": [
        { "type": "medication" },
        { "type": "medication" }
      ],
      "assertNeedsClarification": true
    },
    {
      "name": "Medication-by-name (Tylenol and Metformin → two med events)",
      "input": "Tylenol and Metformin",
      "expectedEvents": [
        { "type": "medication" },
        { "type": "medication" }
      ],
      "assertNeedsClarification": true
    },
    {
      "name": "Supplement-by-name (fish oil → supplement)",
      "input": "fish oil",
      "expectedEvents": [{ "type": "supplement" }],
      "assertNeedsClarification": true
    },
    {
      "name": "Supplement-by-name (vitamin D with calcium → two supplements)",
      "input": "vitamin D with calcium",
      "expectedEvents": [
        { "type": "supplement" },
        { "type": "supplement" }
      ],
      "assertNeedsClarification": true
    }
  ]
}
